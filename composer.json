{
    "name": "code-fusion-technology/laravel-package",
    "license": "MIT",
    "description": "A Laravel package",
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "CodeFusion\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodeFusion\\Tests\\": "tests/",
            "Database\\Factories\\": "database/factories",
            "App\\": "app"
        }
    },
    "authors": [
        {
            "name": "Bruno Henrique da Costa",
            "email": "bruno.costa@mobiis.com.br"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-bcmath": "*",
        "hashids/hashids": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.1",
        "pestphp/pest": "^3.7",
        "laravel/pint": "^1.21",
        "pestphp/pest-plugin-laravel": "^3.1",
        "larastan/larastan": "^3.0",
        "rector/rector": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "refactor": "rector",
        "lint": "pint",
        "test:refactor": "rector --dry-run",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse --ansi src/",
        "test:unit": "pest --colors=always --coverage --min=100 --compact",
        "test:debug": "laradumps check --dir=src,tests --text=dump,dd",
        "test": [
            "@test:debug",
            "@test:refactor",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodeFusion\\Crypt\\Provider\\CryptServiceProvider"
            ]
        }
    }
}
