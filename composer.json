{
    "name": "code-fusion/laravel-package",
    "autoload": {
        "psr-4": {
            "CodeFusion\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Bruno Henrique da Costa",
            "email": "bruno.costa@mobiis.com.br"
        }
    ],
    "require": {
        "illuminate/database": "^11.0 | ^12.1",
        "illuminate/http": "^11.0 | ^12.1",
        "hashids/hashids": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.1",
        "pestphp/pest": "^3.7"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
